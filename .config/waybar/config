"custom/battery_BAT0_not_existing": {
  "interval": 20,
  "max-length": 7,
  "min-length": 7,
  "align": 0,
  "exec": "if ! test -d /sys/class/power_supply/BAT0; then echo 1; fi",
  "return-type": "text",
  "format": "{icon}",
  "format-icons": "≤▒θσ BAT0",
  "tooltip": false
},


