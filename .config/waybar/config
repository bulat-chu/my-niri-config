"clock": {
    "interval": 1,
    "min-length": 15,
    "max-length": 15,
    "align": 0,
    "timezone": "",
    "locale": "en_US.UTF-8",
    "format": " ΎΑΩ {:%I:%M:%S %p}",
    "format-alt": " ΎΒ│ {:%b %d,%Y}", // Icon: calendar-alt

    "tooltip": true,
    "tooltip-format": "<tt><small>{calendar}</small></tt>",
  	"calendar": {
  		"mode"		: "month",
  		"mode-mon-col"	: 3,
  		"weeks-pos"	: "left",
  		"on-scroll"	: 1,
  		"on-click-right": "mode",
  		"format": {
			"months"	: "<span color='#00FF99'>{}</span>",
			"days"		: "<span color='#FFFFFF'>{}</span>",
			"weeks"		: "<span color='#00FF99'>{}</span>",
			"weekdays"	: "<span color='#33CCFF'>{}</span>",
			"today"		: "<span color='#FF0000'><b><u>{}</u></b></span>",
  		}
  	},
        "actions": {
  		"on-click-right"	: "mode",
  		"on-click-forward"	: "tz_up",
  		"on-click-backward"	: "tz_down",
  		"on-scroll-up"		: "shift_up",
  		"on-scroll-down"	: "shift_down"
  	}
},


// ---------------------------------------------------------------------------------------------------------

"cpu": {
    "min-length": 7,
    "max-length": 7,
    "align":0,
    "interval": 1,
	"format": "{icon}  {usage}%",
	"format-icons": [
     	"<span color='#33ccff'>≤░Ε░</span>", 
        "<span color='#00d4ff'>≤░ςη</span>",
        "<span color='#00dcf9'>≤░ςθ</span>",
        "<span color='#00e2ef'>≤░ςι</span>",
        "<span color='#00e8e3'>≤░ςκ</span>",
        "<span color='#00eed6'>≤░ςλ</span>",
        "<span color='#00f5c5'>≤░ςμ</span>",
        "<span color='#00fbb0'>≤░ςν</span>",
        "<span color='#00ff99'>≤░ςξ</span>"
	],

    "tooltip": false,
    "on-click-right": "alacritty -e 'htop'"
},


// ---------------------------------------------------------------------------------------------------------

"memory": {
    "interval": 10,
    "min-length": 7,
    "max-length": 7,
    "align": 0,
    "format": "{icon} {percentage}%",
    "format-icons": [
	    "<span color='#33ccff'>≤░Ε░</span>",
        "<span color='#00d4ff'>≤░ςη</span>",
        "<span color='#00dcf9'>≤░ςθ</span>",
        "<span color='#00e2ef'>≤░ςι</span>",
        "<span color='#00e8e3'>≤░ςκ</span>",
        "<span color='#00eed6'>≤░ςλ</span>",
        "<span color='#00f5c5'>≤░ςμ</span>",
        "<span color='#00fbb0'>≤░ςν</span>",
        "<span color='#00ff99'>≤░ςξ</span>"
	],
		
    "align": 0,
    "tooltip": true,
    "tooltip-format": "Memory: {used:0.1f}G/{total:0.1f}G
SWAP:   {swapUsed:0.1f}G/{swapTotal:0.1f}G",
    "warning": 85,
    "critical": 95
},


// ---------------------------------------------------------------------------------------------------------

"network": {
  "interval"  : 3,
  "min-length": 2,
  "max-length": 2,
  "align"     : 0,

  "format-wifi"         : "{icon}",
  "format-icons"        : ["≤░νψ","≤░νθ","≤░νλ","≤░νξ","≤░νρ"], 
  "format-ethernet"     : "≤░▒Φ",  //Ethernet available
  "format-linked"       : "≤░▓Λ",  //Link Up  
  "format-disconnected"	: "≤░▒θ",  //Disconnected
  "format-disabled"	    : "≤░▓ε",  //Admin Down
  
  "tooltip"                     : true,
  "tooltip-format-ethernet"	:"IP:    {ipaddr}/{cidr}
≤░πζ {bandwidthUpBits}
≤░πΩ {bandwidthDownBits}",
  "tooltip-format-wifi":
"Signal:{signalStrength}% ({signaldBm}dBm) \n
IP:    {ipaddr}/{cidr}
ESSID: {essid}
Frequency: {frequency} GHz
≤░πζ {bandwidthUpBits}
≤░πΩ {bandwidthDownBits}",
  "on-click-right": "exec alacritty -e nmtui"
},


// ---------------------------------------------------------------------------------------------------------

"bluetooth": {
  // "controller": "controller1", // specify the alias of the controller if there are more than 1 on the system
  "max-length": 2,
  "min-length": 2,
  "align": 0,
  "tooltip": true,
  "on-click": "exec rfkill toggle bluetooth",
  "on-click-right": "exec alacritty -e bluetui",

  "format": "ΎΛΥ",
  "format-connected": "≤░Γ▒",
  "format-no-controller": "≤░Γ▓",
  "format-disabled": "≤░Γ▓",
  "format-off": "≤░Γ▓",
  "format-on": "≤░Γψ",

  "tooltip-format": "Host name: {controller_alias} \nAddress:   {controller_address}",
  "tooltip-format-connected": "Host name: {controller_alias} \nAddress:   {controller_address} \n \nConnected: \n{device_enumerate}",
  "tooltip-format-enumerate-connected": "Device:    {device_alias} \nAddress:   {device_address} \n",
  "tooltip-format-no-controller": "Controller not found",
  "tooltip-format-disabled": "Hardware Off \nBluetui won't work",
  "tooltip-format-off": "Soft Off",
  "tooltip-format-on": "Host name: {controller_alias} \nAddress:   {controller_address}",
},

// ---------------------------------------------------------------------------------------------------------

"idle_inhibitor": {
    "max-length": 3,
    "min-length": 3,
    "align": 0,
    "tooltip": false,
    "format": "{icon} ",
    "format-icons": {
    "activated": "≤░Τ│",
    "deactivated": "≤░Τ▓"
    }
},


// ---------------------------------------------------------------------------------------------------------

"backlight": {
    "max-length": 2,
    "min-length": 2,
    "align": 0,
    "tooltip": false,
    "device": "/sys/class/backlight/",
    "format": "{icon}",
    "on-click-right": "brightnessctl -c backlight set 50%",
    "format-icons": ["≤░Δη", "≤░Δζ", "≤░Δι"],
  "on-scroll-down": "brightnessctl --min-value=1 -c backlight set 1%-",
    "on-scroll-up": "brightnessctl --min-value=1 -c backlight set +1%",
    },


// ---------------------------------------------------------------------------------------------------------

  "pulseaudio": {
    "format": "{icon} {volume}%",
    "tooltip": false,
    "tooltip-format": "Volume: {volume}%",
    "format-muted": "Ό╗ρ  Mute",
    "on-click": "wpctl set-mute @DEFAULT_SINK@ toggle",
    "on-click-right": "hyprpwcenter",
    "on-scroll-up": "wpctl set-volume -l 1.0 @DEFAULT_SINK@ 2%+",
    "on-scroll-down": "wpctl set-volume @DEFAULT_SINK@ 2%-",
    "format-icons": {
      "headphone": "ΎΑξ ",
      "hands-free": "ΎΑξ ",
      "headset": "ΎΑξ ",
      "phone": "ΎΓΧ ",
      "portable": "ΎΓΧ ",
      "car": "ΎΗ╣ ",
      "default": ["ΎΑο ","ΎΑπ ","ΎΑρ "]
//      "default": ["ΎΑο - - - - -", "ΎΑοέΠ╜ - - - -", "ΎΑοέΠ╜έΠ╜ - - -","ΎΑοέΠ╜έΠ╜έΠ╜ - -","ΎΑοέΠ╜έΠ╜έΠ╜έΠ╜ -","ΎΑοέΠ╜έΠ╜έΠ╜έΠ╜έΠ╜"]
      },
    "max-length": 7,
    "min-length": 7,
    "align": 0,
  },


// ---------------------------------------------------------------------------------------------------------

  "pulseaudio#microphone": {
    "format": "{format_source}",
    "format-source": "ΎΕ░ {volume}%",
    "tooltip": false,
    "tooltip-format": "Mic volume: {volume}%",
    "format-source-muted": "ΎΕ▒  Mute",
    "on-click": "wpctl set-mute @DEFAULT_SOURCE@ toggle",
    "on-click-right": "hyprpwcenter",
    "on-scroll-up": "wpctl set-volume -l 1.0 @DEFAULT_SOURCE@ 2%+",
    "on-scroll-down": "wpctl set-volume @DEFAULT_SOURCE@ 2%-",
    "max-length": 7,
    "min-length": 7,
    "align": 0
  },


// ---------------------------------------------------------------------------------------------------------

"mpris": {
  "max-length": 3,
  "min-length": 3,
  "align": 0,
  "on-click": "playerctl --all-players play-pause",
    "tooltip": true,
    "tooltip-format": "Status - {status_icon}
Player - {player}

Length - {length}
Artist - {artist}
Album  - {album}
Title  - {title}",
    "format": "{player_icon}",
    "format-paused": "{status_icon}",
    "player-icons": {
      "default": "ΎΒΜ",
       },
    "status-icons": {
      "playing": "ΎΒΜ",
      "paused":  "ΎΒΝ",
      "stopped": "ΎΒΞ"
      },
},


// ---------------------------------------------------------------------------------------------------------

"mpd": {
  "interval": 5,
  "max-length": 2,
  "min-length": 2,
  "on-click": "playerctl --player mpd play-pause",
  "on-click-right": "exec alacritty -e ncmpcpp",
  "on-click-middle": "exec alacritty -e pw-top",
  "on-scroll-up": "playerctl --player mpd volume 0.01+",
  "on-scroll-down": "playerctl --player mpd volume 0.01-",
  "format": "{stateIcon}",
  "format-disconnected": "ΏθΟ╢",
  "format-stopped": "έβς",
  "unknown-tag": "N/A",
  "consume-icons": {
    "on": "ΎΔΕ " // Icon shows only when "consume" is on
  },
  "random-icons": {
    "off": "ΎΒ┤  Off",
    "on": "ΎΒ┤  On"
  },
  "repeat-icons": {
    "on": "ΎΑη  On",
    "off": "ΎΑη  Off"
  },
  "single-icons": {
    "on": "ΎΑη  Single"
  },
  "state-icons": {
    "paused": "ΎΒΝ",
    "playing": "ΎΒΜ",
    "stopped": "ΎΒΞ"
  },

  "artist-len": 50,
  "title": 50,
  "album-len": 50,



  "tooltip-format": "State  -  {stateIcon}    {randomIcon}    {repeatIcon}{singleIcon}

Time   - {elapsedTime:%M:%S}
Length - {totalTime:%M:%S}

Artist - {artist}
Title  - {title} 
Album  - {album}",

  "tooltip-format-disconnected": "MPD (disconnected)",
},


// ---------------------------------------------------------------------------------------------------------

"custom/blue_light_filter": {
  "max-length": 2,
  "min-length": 2,
  "align": 0,
  "tooltip": false,
  "exec": "~/.config/niri/scripts/sunsetr_control.sh",
  "return-type": "json",
  "on-click": "~/.config/niri/scripts/sunsetr_control.sh toggle",
  "signal": 9
},


// ---------------------------------------------------------------------------------------------------------

"custom/backlight_external": {
  "max-length": 3,
  "min-length": 3,
  "align": 0,
  "tooltip": true,
  "exec": "~/.config/niri/scripts/monitor_control.sh",
  "return-type": "json",
  "on-click": "~/.config/niri/scripts/monitor_control.sh toggle",
  "on-click-right": "ddcutil -d 1 setvcp 10 50 --sleep-multiplier=0.1 --noverify --disable-capabilities-cache",
  "on-scroll-up": "ddcutil -d 1 setvcp 10 + 20 --sleep-multiplier=0.1 --noverify --disable-capabilities-cache",
  "on-scroll-down": "ddcutil -d 1 setvcp 10 - 20 --sleep-multiplier=0.1 --noverify --disable-capabilities-cache",
  "signal": 8
},

// ---------------------------------------------------------------------------------------------------------

"custom/meowdo": {
  "max-length": 3,
  "min-length": 3,
  "align": 0,
  "tooltip": true,
  "tooltip-format": "Task Manager",
  "format": "{icon}",
  "format-icons": " ≤░Εδ",
  "on-click": "alacritty -e 'meowdo'",
},
  
  // ---------------------------------------------------------------------------------------------------------

"custom/powermenu": {
  "max-length": 3,
  "min-length": 3,
  "align": 0,
  "tooltip": true,
  "tooltip-format": "Left  - poweroff \nRight - reboot",
  "on-click": "poweroff",
  "on-click-right": "reboot",
  "format":"ΎΑΣ",
},
// ---------------------------------------------------------------------------------------------------------
}
